TG_BOT_TOKEN=REPLACE_WITH_TELEGRAM_BOT_TOKEN
TG_CHAT_ID=REPLACE_WITH_TELEGRAM_USER_OR_CHAT_ID

# Optional but useful to avoid GitHub API rate limits.
# GITHUB_TOKEN=ghp_REPLACE_ME

# Optional poll-all parallelism. Different upstream projects can build at once;
# targets from the same upstream project still build sequentially.
# BUILD_JOBS=3

# Optional poll-all release window. All stable upstream releases are synced from
# GitHub, but only the newest N stable versions are built/uploaded.
# PUSH_RELEASE_LIMIT=3

# Optional local source cache. Each upstream repo gets its own branch, such as
# autobuild/xray or autobuild/mihomo, then the actual build uses a temp clone.
# SOURCE_CACHE_DIR=D:/release-autobuild-sources
# SOURCE_BRANCH_PREFIX=autobuild
# SOURCE_BRANCH_XRAY=autobuild/xray-release

# Optional Android build settings.
# ANDROID_HOME=/path/to/Android/Sdk
# ANDROID_SDK_ROOT=/path/to/Android/Sdk
# JAVA_HOME=/path/to/jdk-17

# Optional Momogram Telegram API credentials.
# TELEGRAM_APP_ID=123456
# TELEGRAM_APP_HASH=0123456789abcdef0123456789abcdef

# Optional: otherwise v2rayNG auto-downloads libv2ray.aar from AndroidLibXrayLite.
# V2RAYNG_LIBV2RAY_AAR=/path/to/libv2ray.aar
