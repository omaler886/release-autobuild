# Copy this file to a private location on the remote builder and source it
# before running build_release.py. Do not commit the real bot token.

export TG_BOT_TOKEN="REPLACE_WITH_TELEGRAM_BOT_TOKEN"
export TG_CHAT_ID="REPLACE_WITH_TELEGRAM_USER_OR_CHAT_ID"

# Optional but useful to avoid GitHub API rate limits.
# export GITHUB_TOKEN="ghp_REPLACE_ME"

# Optional Android build settings.
# export ANDROID_HOME="$HOME/Android/Sdk"
# export ANDROID_SDK_ROOT="$ANDROID_HOME"
# export JAVA_HOME="/usr/lib/jvm/java-17-openjdk-amd64"

# Momogram requires Telegram API credentials in local.properties.
# export TELEGRAM_APP_ID="123456"
# export TELEGRAM_APP_HASH="0123456789abcdef0123456789abcdef"

# Optional signing settings for Momogram release builds.
# export ALIAS_NAME="release"
# export KEYSTORE_PASS="change-me"
# export ALIAS_PASS="change-me"

# v2rayNG may need a libv2ray.aar copied in from AndroidLibXrayLite releases.
# export V2RAYNG_LIBV2RAY_AAR="$HOME/libv2ray.aar"
