# Copy this file to a private location on the remote builder and source it
# before running build_release.py. Do not commit the real bot token.

export TG_BOT_TOKEN="REPLACE_WITH_TELEGRAM_BOT_TOKEN"
export TG_CHAT_ID="REPLACE_WITH_TELEGRAM_USER_OR_CHAT_ID"

# Optional but useful to avoid GitHub API rate limits.
# export GITHUB_TOKEN="ghp_REPLACE_ME"
# export GITHUB_API_RETRIES="3"
# export GITHUB_API_TIMEOUT="60"

# Optional poll-all parallelism. Different upstream projects can build at once;
# targets from the same upstream project still build sequentially.
# export BUILD_JOBS="3"

# Optional poll-all release window. All stable upstream releases are synced from
# GitHub, but only the newest N stable versions are built/uploaded.
# export PUSH_RELEASE_LIMIT="3"

# Optional remote branch prefix for generated upstream release metadata branches.
# GitHub Actions can create branches like upstream/xray and upstream/mihomo.
# export UPSTREAM_BRANCH_PREFIX="upstream"

# Optional local source cache. Each upstream repo gets its own branch, such as
# autobuild/xray or autobuild/mihomo, then the actual build uses a temp clone.
# export SOURCE_CACHE_DIR="/opt/release-autobuild-sources"
# export SOURCE_BRANCH_PREFIX="autobuild"
# export SOURCE_BRANCH_XRAY="autobuild/xray-release"

# Optional Android build settings.
# export ANDROID_HOME="$HOME/Android/Sdk"
# export ANDROID_SDK_ROOT="$ANDROID_HOME"
# export JAVA_HOME="/usr/lib/jvm/java-17-openjdk-amd64"

# Optional Momogram Telegram API credentials.
# export TELEGRAM_APP_ID="123456"
# export TELEGRAM_APP_HASH="0123456789abcdef0123456789abcdef"

# Optional signing settings for Momogram release builds.
# If KEYSTORE_PATH is omitted, the script creates a temporary release.keystore.
# export KEYSTORE_PATH="$HOME/release.keystore"
# export ALIAS_NAME="release"
# export KEYSTORE_PASS="change-me"
# export ALIAS_PASS="change-me"

# Optional: otherwise v2rayNG auto-downloads libv2ray.aar from AndroidLibXrayLite.
# export V2RAYNG_LIBV2RAY_AAR="$HOME/libv2ray.aar"
